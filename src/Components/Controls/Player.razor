@using Microsoft.Extensions.Logging
@using Microsoft.FluentUI.AspNetCore.Components
@using Microsoft.Extensions.Localization
@using Microsoft.Extensions.Options
@using PCRadio.DataAccess.Interfaces
@using _regular = Microsoft.FluentUI.AspNetCore.Components.Icons.Regular
@using _filled = Microsoft.FluentUI.AspNetCore.Components.Icons.Filled
@using PCRadio.DataAccess.Models
@using PCRadio.Extensions
@using PCRadio.Services.Interfaces
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime
@inject IOptions<AppSettings> options
@inject IStations stations
@inject ILinkOpeningService linkOpeningService
@inject IStringLocalizer<Player> localizer
@inject IHttpClientFactory httpClientFactory
@inject IHistoryRecords historyRecords
@inject IAppStateService appStateService
@inject IToastService toastService
@inject ILogger<Player> logger
@inject IDialogService dialogService
@inject IMetadataService metadataService

<FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Class="player">
    <img class="logo" src="@Station?.Logo" alt="@Station?.Name" title="@Station?.Description" loading="lazy" />
    <FluentStack Orientation="Orientation.Vertical" VerticalAlignment="VerticalAlignment.Top" VerticalGap="2">
        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
            @Station?.GetCountryIcon()
            <FluentButton IconStart="@(Station!.IsFavorite ? new _filled.Size20.Heart() : new _regular.Size20.Heart())"
                          Color="Color.Accent" OnClick="@ToggleFavorite" Title="@localizer["AddToFavorites"]" />
            <b>@Station?.Name</b>
            <span>(@_country @_cities)</span>
        </FluentStack>
        <i>@_genres @_subgenres</i>
        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center"
                     HorizontalGap="2">
            <FluentButton Id="btnSearch" IconStart="@(new _regular.Size20.VideoClip())" Color="Color.Accent"
                          OnClick="@Search" Disabled="@(string.IsNullOrEmpty(SearchText))"
                          Title="@localizer["SearchInYoutube"]" />
            <FluentButton Id="btnSearch" IconStart="@(new _regular.Size20.Search())" Color="Color.Accent"
                          OnClick="@OpenSearchPanel" Disabled="@(string.IsNullOrEmpty(SearchText))"
                          Title="@localizer["SearchInZ3FM"]" />
            <div id="NowPlaying"
                 style="color:var(--accent-fill-rest);font-size: 12px;@(string.IsNullOrEmpty(SearchText) ? "display: none;" : "")">
            </div>
        </FluentStack>
    </FluentStack>
    <FluentSpacer />
    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center"
                 HorizontalAlignment="HorizontalAlignment.Right" style="width: 130px;">
        <FluentButton Id="popoverButton" Class="player-button" IconStart="@(new _regular.Size48.Speaker2())"
                      Color="Color.Accent" OnClick="@(() => _isPopoverVisible = !_isPopoverVisible)"
                      Title="@localizer["Volume"]" />
        <FluentButton Class="player-button"
                      IconStart="@(_isPlaying ? new _regular.Size48.Pause() : new _regular.Size48.Play())" Color="Color.Accent"
                      OnClick="@Play" Title="@localizer["PlayStop"]" />
    </FluentStack>
</FluentStack>
<FluentPopover AnchorId="popoverButton" @bind-Open="_isPopoverVisible" Style="width: 90px; height: 260px;"
               VerticalPosition="VerticalPosition.Top" HorizontalPosition="HorizontalPosition.Left">

    <Body>
        <FluentSlider Orientation="Orientation.Vertical" Min="0.0" Max="1.0" Step="0.01" ValueChanged="@SetVolume"
                      Value="@(1.0 - _volume)" TValue="double" Style="width: 30px; height: 200px;">
            <FluentSliderLabel Position="1.0">0%</FluentSliderLabel>
            <FluentSliderLabel Position="0.75">25%</FluentSliderLabel>
            <FluentSliderLabel Position="0.5">50%</FluentSliderLabel>
            <FluentSliderLabel Position="0.25">75%</FluentSliderLabel>
            <FluentSliderLabel Position="0.0">100%</FluentSliderLabel>
        </FluentSlider>
    </Body>
</FluentPopover>
<audio id="audio" src="@AudioUrl" controls style="display: none;" onerror="@ShowMessage" onstalled="@ShowMessage" />
<script>
    var playerIntervalId;
    var timeout = 5000;

    function setCurrentTrackName(value) {
        var div = document.getElementById("NowPlaying");
        if (div && div.innerHTML != value) {
            div.innerHTML = value;
        }
    }

    window.setPageRef = (dotNetRef) => {
        window.initComponent = (titleDelay) => {
            timeout = titleDelay || timeout;
        };

        window.getCurrentTrackName = () => {
            var player = document.getElementById("audio");
            if (player && player.src) {
                var name = player.src.split("/")[3];
                if (name) {
                    name = name.substring(0, name.indexOf("-"));
                    dotNetRef.invokeMethodAsync('GetCurrentTrackNameAsync', name).then(result => {
                        if (result) {
                            setCurrentTrackName(result);
                        }
                    }).catch(error => {
                        console.error("Error invoking GetCurrentTrackNameAsync:", error);
                        setCurrentTrackName("");
                    });
                }
            }
            else {
                setCurrentTrackName("");
            }
        };

        initComponent();
        playerIntervalId = setInterval(getCurrentTrackName, timeout);
    };

    window.cleanupPlayer = () => {
        if (playerIntervalId) {
            clearInterval(playerIntervalId);
            playerIntervalId = null;
        }
    };

    function playAudio(isPlaying) {
        var player = document.getElementById("audio");
        if (player) {
            if (isPlaying && player.paused) {
                player.play().catch(error => {
                    console.error("Error playing audio:", error);
                });
            } else if (!isPlaying && !player.paused) {
                player.pause();
            }
        }
    }

    function setVolume(volume) {
        var player = document.getElementById("audio");
        if (player) {
            player.volume = volume;
        }
    }
</script>

@code {
    [Parameter]
    public int? StationId { get; set; }
    private HttpClient? httpClient;

    private bool _isPlaying;
    private string? _country;
    private string? _cities;
    private string? _genres;
    private string? _subgenres;
    private string? _searchText = string.Empty;
    private string? SearchText
    {
        get => _searchText;
        set
        {
            if (_searchText != value)
            {
                _searchText = value;
                StateHasChanged();
            }
        }
    }
    private double _volume = 0.5;
    private bool _isPopoverVisible;
    private Station? Station { get; set; }
    private DotNetObjectReference<Player>? thisRef;
    private HistoryRecordEqualityComparer historyRecordEqualityComparer = new HistoryRecordEqualityComparer();
    private IDialogReference? searchDialogReference;

    string AudioUrl
    {
        get
        {
            if (Station?.Stream.EndsWith("-med") == true)
            {
                var quality = options.Value.GetQuality();
                return Station.Stream.Replace("-med", $"-{quality}");
            }

            return Station?.Stream ?? string.Empty;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        httpClient = httpClientFactory.CreateClient("PCRadio.Player.Client");
        await base.OnInitializedAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var timeout = options?.Value?.TitleDelayMilliseconds ?? 5000;
                if (timeout < 1000)
                {
                    timeout = 5000;
                }

                thisRef = DotNetObjectReference.Create(this);
                await JSRuntime.InvokeVoidAsync("setPageRef", thisRef);
                await JSRuntime.InvokeVoidAsync("initComponent", timeout);
                logger?.LogInformation("Player initialized");
            }
            catch (Exception ex)
            {
                logger?.LogError(ex, "Error initializing player");
            }
        }

        try
        {
            await JSRuntime.InvokeVoidAsync("playAudio", _isPlaying);
        }
        catch (Exception ex)
        {
            logger?.LogError(ex, "Error controlling audio playback");
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (StationId.HasValue && Station?.Id != StationId.Value)
        {
            SearchText = string.Empty;
            Station = await stations.GetStationAsync(StationId.Value);

            if (Station != null)
            {
                _country = Station.Country?.Name ?? string.Empty;
                _cities = string.Join(", ", Station.StationCities?.Select(x => x.City?.Name)
                .Where(x => !string.IsNullOrEmpty(x)) ?? Array.Empty<string>());
                _genres = string.Join(", ", Station.StationGenres?.Select(x => x.Genre?.Name)
                .Where(x => !string.IsNullOrEmpty(x)) ?? Array.Empty<string>());
                _subgenres = string.Join(", ", Station.StationSubGenres?.Select(x => x.SubGenre?.Name)
                .Where(x => !string.IsNullOrEmpty(x)) ?? Array.Empty<string>());
                StateHasChanged();
            }
        }

        await base.OnParametersSetAsync();
    }

    private async Task Play()
    {
        _isPlaying = !_isPlaying;
        try
        {
            await JSRuntime.InvokeVoidAsync("playAudio", _isPlaying);
        }
        catch (Exception ex)
        {
            logger?.LogError(ex, "Error controlling playback");
        }
    }

    private async Task SetVolume(double volume)
    {
        // Inverted because slider goes from top (1.0) to bottom (0.0)
        _volume = 1.0 - volume;
        try
        {
            await JSRuntime.InvokeVoidAsync("setVolume", _volume);
        }
        catch (Exception ex)
        {
            logger?.LogError(ex, "Error setting volume");
        }
    }

    private async Task ShowMessage()
    {
        if (Station != null)
        {
            var message = $"{localizer["StreamNotAvailable"]}: {Station.Name} ({AudioUrl})";
            toastService.ShowError(message, null, localizer["CopyUrl"],
                EventCallback.Factory.Create<ToastResult>(this, async () =>
                {
                    await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", AudioUrl);
                }));

            _isPlaying = false;
            try
            {
                await JSRuntime.InvokeVoidAsync("playAudio", _isPlaying);
            }
            catch (Exception ex)
            {
                logger?.LogError(ex, "Error stopping playback after stream error");
            }
        }
    }

    private async Task ToggleFavorite()
    {
        if (Station != null)
        {
            Station.IsFavorite = !Station.IsFavorite;
            await stations.SetFavoriteAsync(Station.Id, Station.IsFavorite);
            appStateService.FavoriteStation = new FavoriteStation
            {
                StationId = Station.Id,
                IsFavorite = Station.IsFavorite
            };
        }
    }

    private void Search()
    {
        if (!string.IsNullOrWhiteSpace(SearchText) && options?.Value != null)
        {
            try
            {
                var encodedText = Uri.EscapeDataString(SearchText);
                var searchUrl = string.Format(options.Value.TrackSearchUrl, encodedText);
                linkOpeningService.OpenUrl(searchUrl);
            }
            catch (Exception ex)
            {
                logger?.LogError(ex, "Error performing search for: {SearchText}", SearchText);
            }
        }
    }

    private async Task OpenSearchPanel()
    {
        var content = SearchText ?? string.Empty;
        var parameters = new DialogParameters<string>()
        {
            Content = content,
            Alignment = HorizontalAlignment.Right,
            Title = localizer["SearchInZ3FM"],
            Width = "450px",
        };
        searchDialogReference = await dialogService.ShowPanelAsync<SearchList>(content, parameters);
    }

    [JSInvokable]
    public async Task<string> GetCurrentTrackNameAsync(string name)
    {
        var station = Station;

        if (httpClient == null || string.IsNullOrWhiteSpace(name) || options?.Value == null || station == null)
        {
            return string.Empty;
        }

        var result = await metadataService.GetTitleAsync(AudioUrl);
        if (result.IsSuccess && !string.IsNullOrWhiteSpace(result.Title))
        {
            SearchText = result.Title;
            await AddToHistoryAsync(SearchText, station.Name, DateTime.Now);
            return SearchText;
        }
        else
        {
            return string.Empty;
        }
    }

    public async Task AddToHistoryAsync(string searchText, string stationName, DateTime startTime,
        CancellationToken cancellationToken = default)
    {
        var lastTrackName = appStateService?.LastHistoryRecord?.TrackName;
        var lastStartTime = appStateService?.LastHistoryRecord?.StartTime;
        var record = new HistoryRecord
        {
            StartTime = (searchText == lastTrackName) ? lastStartTime ?? startTime : startTime,
            StationName = stationName,
            TrackName = searchText
        };

        if (!historyRecordEqualityComparer.Equals(appStateService?.LastHistoryRecord, record))
        {
            try
            {
                await historyRecords.AddAsync(record, cancellationToken);
                appStateService?.LastHistoryRecord = record;
            }
            catch (Exception ex)
            {
                logger?.LogError(ex, "Error adding history record for: {StationName} - {TrackName}", stationName, searchText);
            }
        }
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        try
        {
            // Clean up JavaScript resources
            await JSRuntime.InvokeVoidAsync("cleanupPlayer");
        }
        catch (Exception ex)
        {
            logger?.LogWarning(ex, "Error cleaning up player resources");
        }

        thisRef?.Dispose();
        GC.SuppressFinalize(this);
    }
}